---
// Our Products — wireframe 8 (pure ground). The page is ONE gallery of all
// product cutouts grouped by category. Default layout (mobile, reduced-motion,
// no-JS): a vertical list — each category is a horizontal native-scroll rail.
// v1.1 (flag productsPin, desktop, motion on): src/motion/products.ts pins the
// stage and scrubs the whole track horizontally as you scroll vertically — the
// spec's "pinned horizontal gallery" (DESIGN.md scroll grammar). DOM stays in
// logical reading order under the pin (RAILS §1.11). HARD category anchors
// (#men…#new-born incl. the live "#underware" spelling) are preserved.
import { Image, getImage } from 'astro:assets';
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import { slot, resolveImage } from '../lib/images';

const entry = await getEntry('copy', 'our-products');
if (!entry) throw new Error('copy/our-products missing — run: node setup/extract-copy.mjs');
const { title, sections = [], categories = [] } = entry.data as {
  title: string;
  sections: Record<string, any>[];
  categories: { id: string; label: string }[];
};

const REQUIRED = ['men', 'women', 'kid', 'underware', 'new-born'];
const ids = new Set(categories.map((c) => c.id));
const missing = REQUIRED.filter((a) => !ids.has(a));
if (missing.length) throw new Error(`HARD product anchor(s) missing: #${missing.join(', #')} — RAILS.md §4`);

const SLOT_FOR: Record<string, string> = {
  men: 'mens', women: 'womens', kid: 'kids', underware: 'underwear', 'new-born': 'newborn',
};

const rails = await Promise.all(
  categories.map(async ({ id, label }) => {
    const s = slot('products', SLOT_FOR[id]) as { items?: { src: string; alt: string }[] };
    const items = await Promise.all(
      (s.items ?? []).map(async ({ src, alt }) => ({ image: await resolveImage(src), alt: alt ?? '' })),
    );
    return { id, label, items };
  }),
);

const intro: string = sections[0]?.intro ?? '';
if (!intro) throw new Error('copy/our-products: deck intro line missing');

const firstItem = rails.find((r) => r.items.length > 0)?.items[0];
const lcpPreload = firstItem
  ? await getImage({ src: firstItem.image, widths: [380], sizes: '(min-width: 768px) 280px, 62vw', quality: 50, format: 'webp' })
  : undefined;
---
<Base title={`${title} — Rizvi Fashions Limited`} description={intro} pure preloadImage={lcpPreload}>
  <header class="page-head">
    <h1>{title}</h1>
    <p class="page-head__intro">{intro}</p>
  </header>

  <nav class="cat-index" aria-label="Product categories">
    <ul>
      {categories.map(({ id, label }) => (
        <li><a class="u-caps" href={`#${id}`} data-cat-link={id}>{label}</a></li>
      ))}
    </ul>
  </nav>

  <section class="products-pin" data-products-pin>
    <ol class="products-track">
      {rails.map(({ id, label, items }, i) => (
        <li class="cat-panel" id={id} data-cat={id}>
          <header class="cat-panel__head">
            <span class="chapter__num" aria-hidden="true"></span>
            <h2>{label}</h2>
          </header>
          {items.length > 0 ? (
            <div class="cat-panel__viewport">
              <button class="rail-nav rail-nav--prev" type="button" aria-label={`Previous — ${label}`}>
                <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M10 2 L4 8 L10 14" fill="none" stroke="currentColor" stroke-width="2" /></svg>
              </button>
              <ul class="cat-panel__rail" tabindex="0" aria-label={`${label} — product gallery`}>
                {items.map(({ image, alt }, j) => (
                  <li class="cat-img" style={`--j: ${j}`}>
                    <Image
                      src={image}
                      alt={alt}
                      widths={[380]}
                      sizes="(min-width: 768px) 280px, 62vw"
                      loading={i === 0 && j === 0 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 && j === 0 ? 'high' : 'low'}
                      quality={50}
                      format="webp"
                    />
                  </li>
                ))}
              </ul>
              <button class="rail-nav rail-nav--next" type="button" aria-label={`Next — ${label}`}>
                <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M6 2 L12 8 L6 14" fill="none" stroke="currentColor" stroke-width="2" /></svg>
              </button>
            </div>
          ) : (
            <p class="cat-panel__empty u-caps">Imagery for this range is being prepared.</p>
          )}
        </li>
      ))}
    </ol>
  </section>

  <dialog class="lightbox" id="product-lightbox" aria-label="Enlarged product image">
    <img class="lightbox__img" alt="" width="380" height="570" />
  </dialog>

  <script>
    // Reveal each category's images in sequence as the category scrolls into
    // view (works under the corridor scrub and the vertical fallback alike).
    const cats = document.querySelectorAll('.cat-panel');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || !('IntersectionObserver' in window)) {
      cats.forEach((c) => c.classList.add('is-revealing'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('is-revealing'); io.unobserve(e.target); }
          }
        },
        { threshold: 0.2 },
      );
      cats.forEach((c) => io.observe(c));
    }

    // Chevron navigation: each arrow scrolls its range's gallery by ~a screenful.
    document.querySelectorAll('.rail-nav').forEach((btn) => {
      btn.addEventListener('click', () => {
        const vp = btn.closest('.cat-panel__viewport');
        const rail = vp?.querySelector('.cat-panel__rail') as HTMLElement | null;
        if (!rail) return;
        const dir = btn.classList.contains('rail-nav--next') ? 1 : -1;
        rail.scrollBy({ left: dir * rail.clientWidth * 0.8, behavior: 'smooth' });
      });
    });

    // Click any garment → enlarge it alone, centred, in the native <dialog>
    // top-layer (sits above the corridor transforms). Click / Esc closes.
    const lb = document.getElementById('product-lightbox') as HTMLDialogElement | null;
    const lbImg = lb?.querySelector('img');
    if (lb && lbImg) {
      document.addEventListener('click', (e) => {
        const img = (e.target as HTMLElement)?.closest?.('.cat-panel__rail img') as HTMLImageElement | null;
        if (!img || !lb.showModal) return;
        lbImg.src = img.currentSrc || img.src;
        lbImg.alt = img.alt || '';
        lb.showModal();
      });
      lb.addEventListener('click', () => lb.close());
    }
  </script>
</Base>

<style>
  .page-head { padding-block: var(--space-7) var(--space-5); }
  .page-head__intro { font-size: var(--text-md); margin-block-start: var(--space-4); }

  /* products accumulate: as each category enters, its garments slide in one
     after another (per-image stagger via --j), the category itself staying put.
     .js-gated so no-JS shows them all; reduced-motion resolves instantly. */
  .js .cat-img {
    opacity: 0;
    transform: translateX(var(--space-4));
    transition:
      opacity var(--dur-slow) var(--ease-out),
      transform var(--dur-slow) var(--ease-out);
    transition-delay: calc(var(--j) * var(--dur-base));
  }
  .js .cat-panel.is-revealing .cat-img { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .js .cat-img { opacity: 1; transform: none; transition: none; }
  }

  /* category index: dimmed resting; the active category goes ink as the gallery
     scrolls past it (set by products.ts; CSS-only fallback stays static) */
  .cat-index { border-block: var(--rail-w) solid var(--hairline); padding-block: var(--space-3); }
  .cat-index ul { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-4); }
  .cat-index a {
    color: var(--ink-muted);
    text-decoration: none;
    display: inline-block;
    padding-block: var(--space-1);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .cat-index a:hover { color: var(--ink); }
  .cat-index a.is-active { color: var(--ink); }

  /* ---- DEFAULT layout (mobile / reduced-motion / no-JS): vertical list, each
     category a horizontal native-scroll rail. This is also the reduced-motion
     designed alternative the spec calls for. */
  .products-track {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-block: var(--space-6);
  }
  .cat-panel { counter-increment: chapter; }
  .cat-panel__head { margin-block-end: var(--space-4); }
  .cat-panel__rail {
    list-style: none;
    /* TWO ROWS of smaller images (owner): garments fill into two rows and the
       range extends horizontally for the overflow — everything visible on one
       screen, the extras reached by an always-present horizontal scrollbar. */
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(2, auto);
    grid-auto-columns: max-content;
    justify-content: start;
    align-content: start;
    gap: var(--space-3) var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x proximity;
    padding-block: var(--space-2);
    /* no scrollbar — the flanking chevron buttons are the navigation (owner) */
    scrollbar-width: none;
  }
  .cat-panel__rail::-webkit-scrollbar { display: none; }
  .cat-panel__rail:focus-visible { outline-offset: var(--space-1); }

  /* viewport: chevron | gallery | chevron, the arrows flanking each range as the
     catalogue navigation (replaces the scrollbar) */
  .cat-panel__viewport {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-3);
  }
  .rail-nav {
    flex: none;
    inline-size: var(--space-6);
    block-size: var(--space-6);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: var(--rail-w) solid var(--hairline);
    color: var(--ink);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .rail-nav:hover,
  .rail-nav:focus-visible { color: var(--accent); border-color: var(--accent); }
  .rail-nav svg { inline-size: var(--space-3); block-size: var(--space-3); }
  .cat-panel__rail > li { scroll-snap-align: start; }
  /* smaller, minimal cards (owner: less screen-space, more elegant) — two quiet
     rows of compact garments rather than a dense wall */
  .cat-panel__rail img {
    height: auto;
    max-height: 24svh;
    width: auto;
    cursor: zoom-in; /* clickable → opens the centred lightbox */
  }
  .cat-panel__empty { color: var(--ink-muted); }

  /* in the corridor each range fills the viewport so the gallery scrolls INSIDE
     its row — between the two chevrons — instead of widening the room past the
     screen (which would push the right chevron off-screen). */
  :global(.hscroll-on .hpanel:has(.cat-panel__viewport)) { width: 100vw; }
  :global(.hscroll-on .hpanel:has(.cat-panel__viewport) .cat-panel) { width: 100%; }
  .cat-panel__viewport { min-width: 0; max-width: 100%; }

  /* ---- LIGHTBOX: a clicked garment enlarges alone, centred on a dim ground.
     Native <dialog> top-layer sits above the corridor transforms. */
  .lightbox {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100dvh;
  }
  /* fill the viewport and centre the single garment on a dimmed ground */
  .lightbox[open] {
    display: grid;
    place-items: center;
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    background: var(--scrim-img);
  }
  .lightbox::backdrop { background: var(--scrim-img); }
  .lightbox__img {
    display: block;
    max-width: 92vw;
    max-height: 88dvh;
    width: auto;
    height: auto;
    margin: auto;
    cursor: zoom-out;
    border: var(--rail-w) solid var(--hairline);
  }

  /* ---- PINNED layout (desktop + motion): products.ts adds .is-pinned, lays the
     track as one horizontal row, and ScrollTrigger scrubs it left as you scroll.
     Applied via a class (not media query) so it only ever engages when the JS
     that drives the scrub is actually running — otherwise the row would overflow. */
  .products-pin.is-pinned { overflow: hidden; }
  .products-pin.is-pinned .products-track {
    flex-direction: row;
    flex-wrap: nowrap;
    gap: var(--space-8);
    height: 100svh;
    align-items: center;
    padding-block: 0;
    width: max-content;
    will-change: transform;
  }
  .products-pin.is-pinned .cat-panel {
    flex: none;
    height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }
  .products-pin.is-pinned .cat-panel__rail {
    overflow: visible;
    padding-block: 0;
  }
  .products-pin.is-pinned .cat-panel__rail img { max-height: var(--card-h); }
</style>
