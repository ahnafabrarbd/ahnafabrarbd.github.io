---
// ComplianceWall — the explained accreditation ledger (PROPOSAL.md Phase 2).
// Turns the silent logo grid into proof a sourcing buyer can act on: each mark
// paired with what it certifies and what risk it removes, sourced from the data
// layer (src/data/accreditations.json), never hardcoded. Rendered as full-width
// keyline rows (the site's editorial ledger idiom — NOT a card grid / badge wall).
import { Image } from 'astro:assets';
import { resolveImage } from '../lib/images';

interface Entry {
  name: string;
  file: string | null;
  certifies?: string;
  removes?: string;
}
interface Props {
  entries: Entry[];
  label: string;
}
const { entries, label } = Astro.props;
const shipped = entries.filter((e) => e.file);
const resolved = await Promise.all(
  shipped.map(async (e) => ({ ...e, image: await resolveImage(e.file!) })),
);
---
<ul class="cwall" aria-label={label}>
  {resolved.map(({ name, image, certifies, removes }) => (
    <li class="cwall__row">
      <span class="cwall__mark">
        <Image src={image} alt={name} width={image.width} height={image.height} loading="lazy" format="webp" />
      </span>
      <div class="cwall__body">
        <h3 class="cwall__name">{name}</h3>
        {certifies && <p class="cwall__certifies">{certifies}</p>}
      </div>
      {removes && (
        <p class="cwall__removes">
          <span class="cwall__removes-k u-caps">Removes</span>
          {removes}
        </p>
      )}
    </li>
  ))}
</ul>

<style>
  /* a compact certification matrix: each mark its own keyline cell, laid out in
     a responsive grid so the full set sits in a few short rows — no long ledger
     that overflows the section-pagination overlay. */
  .cwall {
    list-style: none;
    max-width: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--rail-w);
    background: var(--hairline);
    border: var(--rail-w) solid var(--hairline);
  }
  @media (min-width: 600px) {
    .cwall { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 980px) {
    .cwall { grid-template-columns: 1fr 1fr 1fr; }
  }
  .cwall__row {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--ground);
    align-content: start;
  }
  .cwall__mark {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: var(--space-5);
  }
  .cwall__mark img {
    max-height: var(--space-5);
    width: auto;
    object-fit: contain;
    /* the marks are re-toned #D6D6D6; invert maps them to near-ink on the light
       ground (matches LogoBand, WCAG-safe) */
    filter: invert(1);
  }
  /* certification names read as proper nouns / acronyms — Montserrat, cased, for
     scannability; Cormorant display stays reserved for the section heading. */
  .cwall__name {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--fw-body-strong);
    text-transform: none;
    letter-spacing: normal;
    line-height: var(--leading-snug);
    color: var(--ink);
  }
  .cwall__certifies {
    margin-block-start: var(--space-1);
    max-width: var(--measure-body);
    font-size: var(--text-sm);
    color: var(--ink-body);
  }
  .cwall__removes {
    max-width: var(--measure-body);
    font-size: var(--text-sm);
    color: var(--ink-muted);
  }
  .cwall__removes-k {
    display: block;
    margin-block-end: var(--space-1);
    color: var(--accent);
  }
</style>
